# Copy to deploy/.env and adjust. docker compose reads it automatically.
POSTGRES_DB=hawkeye
POSTGRES_USER=hawkeye
POSTGRES_PASSWORD=hawkeye
POSTGRES_PORT=5432

# When true, the marketdata-loader re-scans every candle from its configured start and upserts
# mismatches (corrects drifted bars, fills gaps) instead of only fetching new candles.
HTB_VERIFY=false
