{
  "schema-version": "1.0",
  "strategy-id": "rsi-movement",
  "version-number": 1,

  "indicators": [
    { "id": "rsi",      "kind": "rsi", "source": "close", "period": "$rsi-period" },
    { "id": "ema-slow", "kind": "ema", "source": "close", "period": "$ema-period" }
  ],

  "rules": {
    "entry-long": {
      "all": [
        { "lt": ["rsi", "$rsi-oversold"] },
        { "gt": ["close", "ema-slow"] }
      ]
    },
    "exit-long": {
      "any": [
        { "gt": ["rsi", "$rsi-overbought"] },
        { "crosses-below": ["close", "ema-slow"] }
      ]
    }
  },

  "requested-risk": {
    "stop-loss-pct": 2.0,
    "take-profit-pct": 4.0,
    "max-position-pct": 10.0
  },

  "execution": {
    "order-type": "market",
    "time-in-force": "gtc",
    "slippage-tolerance-pct": 0.1
  }
}
